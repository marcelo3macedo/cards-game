{
  "$schema": "https://biomejs.dev/schemas/2.3.0/schema.json",

  "files": {
    "ignore": ["node_modules"]
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useImportType": "off"
      }
    }
  }
}
